generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model City {
  id                  String               @id @default(cuid())
  name                String
  state               String
  country             String               @default("India")
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  clients             Client[]
  holdings            Holding[]
  locationSuggestions LocationSuggestion[]
  vendors             Vendor[]

  @@unique([name, state])
  @@map("cities")
}

model HoldingType {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  holdings    Holding[]

  @@map("holding_types")
}

model HsnCode {
  id           String        @id @default(cuid())
  code         String        @unique
  description  String
  gstRate      Decimal       @db.Decimal(5, 2)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  holdings     Holding[]
  invoiceItems InvoiceItem[]
  invoices     Invoice[]

  @@map("hsn_codes")
}

model Holding {
  id                 String              @id @default(cuid())
  code               String              @unique
  name               String
  address            String
  latitude           Decimal?            @db.Decimal(10, 7)
  longitude          Decimal?            @db.Decimal(10, 7)
  width              Decimal             @db.Decimal(10, 2)
  height             Decimal             @db.Decimal(10, 2)
  totalArea          Decimal             @db.Decimal(10, 2)
  illumination       Illumination        @default(NON_LIT)
  facing             String?
  landmark           String?
  status             HoldingStatus       @default(AVAILABLE)
  isInstalled        Boolean             @default(true)
  maintenanceCycle   Int                 @default(90)
  notes              String?
  cityId             String
  holdingTypeId      String
  hsnCodeId          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assetType          AssetType           @default(RENTED)
  vendorId           String?
  bookings           Booking[]
  city               City                @relation(fields: [cityId], references: [id])
  holdingType        HoldingType         @relation(fields: [holdingTypeId], references: [id])
  hsnCode            HsnCode             @relation(fields: [hsnCodeId], references: [id])
  vendor             Vendor?             @relation("VendorHoldings", fields: [vendorId], references: [id])
  inspections        Inspection[]
  locationSuggestion LocationSuggestion?
  maintenanceRecords MaintenanceRecord[]
  ownershipContracts OwnershipContract[]
  tasks              Task[]
  holdingPhotos      HoldingPhoto[]
  legacyImages       String[]            @map("images")

  @@index([status])
  @@index([cityId])
  @@map("holdings")
}

model HoldingPhoto {
  id                 String   @id @default(cuid())
  url                String
  uploadedByUserName String?
  uploadedById       String?
  uploadedBy         User?    @relation("HoldingPhotos", fields: [uploadedById], references: [id], onDelete: SetNull)
  latitude           Decimal? @db.Decimal(10, 7)
  longitude          Decimal? @db.Decimal(10, 7)
  locationText       String?
  createdAt          DateTime @default(now())
  holdingId          String
  holding            Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  @@map("holding_photos")
}

model OwnershipContract {
  id              String         @id @default(cuid())
  contractNumber  String         @unique
  rentAmount      Decimal        @db.Decimal(12, 2)
  rentCycle       RentCycle      @default(MONTHLY)
  contractType    String         @default("ASSET_RENTING") // ASSET_RENTING, SPACE_RENTING
  startDate       DateTime
  endDate         DateTime
  securityDeposit Decimal?       @db.Decimal(12, 2)
  status          ContractStatus @default(ACTIVE)
  notes           String?
  holdingId       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  agreementUrl    String?
  vendorId        String?
  holding         Holding        @relation(fields: [holdingId], references: [id])
  vendor          Vendor?        @relation("VendorContracts", fields: [vendorId], references: [id])

  @@index([vendorId, holdingId, status])
  @@map("ownership_contracts")
}

model Client {
  id                   String    @id @default(cuid())
  name                 String
  contactPerson        String
  email                String?
  phone                String
  gstNumber            String?
  panNumber            String?
  address              String
  isActive             Boolean   @default(true)
  cityId               String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  ledgerId             String?
  agreementDocumentUrl String?
  kycDocumentUrl       String?
  bookings             Booking[]
  city                 City?     @relation(fields: [cityId], references: [id])
  ledger               Ledger?   @relation(fields: [ledgerId], references: [id])
  invoices             Invoice[]
  receipts             Receipt[]

  @@map("clients")
}

model Booking {
  id             String          @id @default(cuid())
  bookingNumber  String          @unique
  startDate      DateTime
  endDate        DateTime
  monthlyRate    Decimal         @db.Decimal(12, 2)
  totalAmount    Decimal         @db.Decimal(12, 2)
  billingCycle   BillingCycle    @default(MONTHLY)
  status         BookingStatus   @default(CONFIRMED)
  notes          String?
  clientId       String
  holdingId      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  freeMountings  Int             @default(0)
  totalMountings Int             @default(0)
  advertisements Advertisement[]
  client         Client          @relation(fields: [clientId], references: [id])
  holding        Holding         @relation(fields: [holdingId], references: [id])
  invoices       Invoice[]
  invoiceItems   InvoiceItem[]
  tasks          Task[]

  @@index([clientId])
  @@index([holdingId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([createdAt])
  @@map("bookings")
}

model Advertisement {
  id                 String    @id @default(cuid())
  campaignName       String
  brandName          String
  artworkDescription String?
  artworkUrl         String?
  installationDate   DateTime?
  removalDate        DateTime?
  status             AdStatus  @default(PENDING)
  notes              String?
  bookingId          String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  booking            Booking   @relation(fields: [bookingId], references: [id])
  tasks              Task[]

  @@map("advertisements")
}

model Task {
  id              String          @id @default(cuid())
  title           String
  description     String?
  taskType        TaskType
  priority        Priority        @default(MEDIUM)
  status          TaskStatus      @default(PENDING)
  scheduledDate   DateTime
  completedDate   DateTime?
  estimatedCost   Decimal?        @db.Decimal(12, 2)
  actualCost      Decimal?        @db.Decimal(12, 2)
  notes           String?
  holdingId       String?
  advertisementId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assignedToId    String?
  bookingId       String?
  executions      TaskExecution[]
  advertisement   Advertisement?  @relation(fields: [advertisementId], references: [id])
  assignedTo      User?           @relation("AssignedToUser", fields: [assignedToId], references: [id])
  booking         Booking?        @relation(fields: [bookingId], references: [id])
  holding         Holding?        @relation(fields: [holdingId], references: [id])

  @@index([taskType])
  @@index([status])
  @@index([holdingId])
  @@index([bookingId])
  @@index([scheduledDate])
  @@index([taskType, status])
  @@map("tasks")
}

model TaskExecution {
  id             String               @id @default(cuid())
  taskId         String
  performedById  String
  status         TaskStatus?
  condition      HoldingCondition
  remarks        String?
  latitude       Decimal              @db.Decimal(10, 7)
  longitude      Decimal              @db.Decimal(10, 7)
  frontViewUrl   String?
  leftViewUrl    String?
  rightViewUrl   String?
  createdAt      DateTime             @default(now())
  illuminationOk Boolean?
  structureOk    Boolean?
  visibilityOk   Boolean?
  performedBy    User                 @relation(fields: [performedById], references: [id])
  task           Task                 @relation(fields: [taskId], references: [id])
  photos         TaskExecutionPhoto[]

  @@map("task_executions")
}

model TaskExecutionPhoto {
  id                 String        @id @default(cuid())
  url                String
  viewType           String? // e.g. FRONT, LEFT, RIGHT
  uploadedByUserName String?
  uploadedById       String?
  uploadedBy         User?         @relation("TaskExecutionPhotos", fields: [uploadedById], references: [id], onDelete: SetNull)
  latitude           Decimal?      @db.Decimal(10, 7)
  longitude          Decimal?      @db.Decimal(10, 7)
  locationText       String?
  createdAt          DateTime      @default(now())
  executionId        String
  execution          TaskExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@map("task_execution_photos")
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String               @unique
  password             String
  plainPassword        String?
  role                 UserRole             @default(STAFF)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  isActive             Boolean              @default(true)
  taskExecutions       TaskExecution[]
  assignedTasks        Task[]               @relation("AssignedToUser")
  holdingPhotos        HoldingPhoto[]       @relation("HoldingPhotos")
  suggestionPhotos     SuggestionPhoto[]    @relation("SuggestionPhotos")
  taskExecutionPhotos  TaskExecutionPhoto[] @relation("TaskExecutionPhotos")
  inspectionPhotos     InspectionPhoto[]    @relation("InspectionPhotos")
  locationSuggestions  LocationSuggestion[] @relation("SuggestedLocations")

  @@map("users")
}

model Inspection {
  id             String            @id @default(cuid())
  inspectionDate DateTime
  inspectorName  String
  condition      HoldingCondition
  illuminationOk Boolean           @default(true)
  structureOk    Boolean           @default(true)
  visibilityOk   Boolean           @default(true)
  remarks        String?
  holdingId      String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  photos         InspectionPhoto[]
  holding        Holding           @relation(fields: [holdingId], references: [id])

  @@map("inspections")
}

model InspectionPhoto {
  id                 String     @id @default(cuid())
  url                String
  caption            String?
  uploadedByUserName String?
  uploadedById       String?
  uploadedBy         User?      @relation("InspectionPhotos", fields: [uploadedById], references: [id], onDelete: SetNull)
  latitude           Decimal?   @db.Decimal(10, 7)
  longitude          Decimal?   @db.Decimal(10, 7)
  locationText       String?
  createdAt          DateTime   @default(now())
  inspectionId       String
  inspection         Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@map("inspection_photos")
}

model MaintenanceRecord {
  id              String            @id @default(cuid())
  maintenanceType MaintenanceType
  description     String
  cost            Decimal           @db.Decimal(12, 2)
  performedDate   DateTime
  performedBy     String
  status          MaintenanceStatus @default(COMPLETED)
  notes           String?
  holdingId       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  holding         Holding           @relation(fields: [holdingId], references: [id])

  @@index([holdingId])
  @@index([status])
  @@index([performedDate])
  @@index([maintenanceType])
  @@map("maintenance_records")
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  invoiceDate    DateTime
  dueDate        DateTime
  subtotal       Decimal       @db.Decimal(12, 2)
  cgstRate       Decimal       @db.Decimal(5, 2)
  sgstRate       Decimal       @db.Decimal(5, 2)
  igstRate       Decimal       @default(0) @db.Decimal(5, 2)
  cgstAmount     Decimal       @db.Decimal(12, 2)
  sgstAmount     Decimal       @db.Decimal(12, 2)
  igstAmount     Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  status         InvoiceStatus @default(DRAFT)
  notes          String?
  clientId       String
  bookingId      String
  hsnCodeId      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  journalEntryId String?
  items          InvoiceItem[]
  booking        Booking       @relation(fields: [bookingId], references: [id])
  client         Client        @relation(fields: [clientId], references: [id])
  hsnCode        HsnCode       @relation(fields: [hsnCodeId], references: [id])
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  receipts       Receipt[]

  @@index([clientId])
  @@index([bookingId])
  @@index([status])
  @@index([invoiceDate])
  @@map("invoices")
}

model InvoiceItem {
  id                  String   @id @default(cuid())
  invoiceId           String
  bookingId           String?
  description         String
  hsnCodeId           String
  quantity            Decimal  @db.Decimal(10, 2)
  rate                Decimal  @db.Decimal(12, 2)
  amount              Decimal  @db.Decimal(12, 2)
  gstRate             Decimal  @db.Decimal(5, 2)
  gstAmount           Decimal  @db.Decimal(12, 2)
  total               Decimal  @db.Decimal(12, 2)
  invoiceItemMetadata Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  booking             Booking? @relation(fields: [bookingId], references: [id])
  hsnCode             HsnCode  @relation(fields: [hsnCodeId], references: [id])
  invoice             Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("invoice_items")
}

model Receipt {
  id               String        @id @default(cuid())
  receiptNumber    String        @unique
  receiptDate      DateTime
  amount           Decimal       @db.Decimal(12, 2)
  paymentMode      PaymentMode
  referenceNo      String?
  notes            String?
  clientId         String
  invoiceId        String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  cashBankLedgerId String
  journalEntryId   String?
  cashBankLedger   Ledger        @relation("ReceiptCashBankLedger", fields: [cashBankLedgerId], references: [id])
  client           Client        @relation(fields: [clientId], references: [id])
  invoice          Invoice       @relation(fields: [invoiceId], references: [id])
  journalEntry     JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@map("receipts")
}

model Ledger {
  id              String        @id @default(cuid())
  name            String        @unique
  code            String        @unique
  type            LedgerType
  isGroup         Boolean       @default(false)
  parentId        String?
  isCash          Boolean       @default(false)
  isBank          Boolean       @default(false)
  isReceivable    Boolean       @default(false)
  isPayable       Boolean       @default(false)
  isRevenue       Boolean       @default(false)
  isTaxOutput     Boolean       @default(false)
  isTaxInput      Boolean       @default(false)
  isSystemLedger  Boolean       @default(false)
  isActive        Boolean       @default(true)
  path            String?
  level           Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clients         Client[]
  journalLines    JournalLine[]
  parent          Ledger?       @relation("LedgerParent", fields: [parentId], references: [id])
  children        Ledger[]      @relation("LedgerParent")
  paymentCashBank Payment[]     @relation("PaymentCashBankLedger")
  receiptCashBank Receipt[]     @relation("ReceiptCashBankLedger")
  vendors           Vendor[]      @relation("VendorLedger")
  liabilityPayments Payment[]     @relation("OtherLiabilityLedger")

  @@map("ledgers")
}

model JournalEntry {
  id          String        @id @default(cuid())
  entryNumber String        @unique
  entryDate   DateTime
  description String?
  source      JournalSource
  sourceId    String?
  status      JournalStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  invoices    Invoice[]
  lines       JournalLine[]
  payments    Payment[]
  receipts    Receipt[]

  @@map("journal_entries")
}

model JournalLine {
  id          String       @id @default(cuid())
  journalId   String
  ledgerId    String
  debit       Decimal?     @db.Decimal(12, 2)
  credit      Decimal?     @db.Decimal(12, 2)
  description String?
  journal     JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  ledger      Ledger       @relation(fields: [ledgerId], references: [id])

  @@map("journal_lines")
}

model Vendor {
  id                   String              @id @default(cuid())
  name                 String
  contactPerson        String?
  email                String?
  phone                String
  gstNumber            String?
  panNumber            String?
  address              String
  isActive             Boolean             @default(true)
  vendorType           String              @default("LANDLORD") // LANDLORD, AGENCY
  accountNumber        String?
  ifsc                 String?
  bankName             String?
  ownershipContractId  String?
  cityId               String?
  ledgerId             String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  agreementDocumentUrl String?
  kycDocumentUrl       String?
  holdings             Holding[]           @relation("VendorHoldings")
  contracts            OwnershipContract[] @relation("VendorContracts")
  payments             Payment[]
  city                 City?               @relation(fields: [cityId], references: [id])
  ledger               Ledger              @relation("VendorLedger", fields: [ledgerId], references: [id])

  @@map("vendors")
}

model Payment {
  id               String        @id @default(cuid())
  paymentNumber    String        @unique
  paymentDate      DateTime
  amount           Decimal       @db.Decimal(12, 2)
  paymentMode      PaymentMode
  referenceNo      String?
  notes            String?
  paymentType        String        @default("VENDOR")
  vendorId           String?
  liabilityLedgerId  String?
  cashBankLedgerId   String
  journalEntryId     String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  cashBankLedger     Ledger        @relation("PaymentCashBankLedger", fields: [cashBankLedgerId], references: [id])
  journalEntry       JournalEntry? @relation(fields: [journalEntryId], references: [id])
  vendor             Vendor?       @relation(fields: [vendorId], references: [id])
  liabilityLedger    Ledger?       @relation("OtherLiabilityLedger", fields: [liabilityLedgerId], references: [id])

  @@map("payments")
}

model LocationSuggestion {
  id           String           @id @default(cuid())
  address      String
  cityId       String
  latitude     Decimal?          @db.Decimal(10, 7)
  longitude    Decimal?          @db.Decimal(10, 7)
  landmark     String?
  description  String?
  photos       SuggestionPhoto[]
  proposedRent Decimal?          @db.Decimal(12, 2)
  ownerName    String?
  ownerPhone   String?
  status       SuggestionStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  convertedAt  DateTime?
  holdingId    String?          @unique
  suggestedById String?
  suggestedByName String?
  city         City             @relation(fields: [cityId], references: [id])
  holding      Holding?         @relation(fields: [holdingId], references: [id])
  suggestedBy  User?            @relation("SuggestedLocations", fields: [suggestedById], references: [id])

  @@map("location_suggestions")
}

model SuggestionPhoto {
  id                 String             @id @default(cuid())
  url                String
  uploadedByUserName String?
  uploadedById       String?
  uploadedBy         User?              @relation("SuggestionPhotos", fields: [uploadedById], references: [id], onDelete: SetNull)
  latitude           Decimal?           @db.Decimal(10, 7)
  longitude          Decimal?           @db.Decimal(10, 7)
  locationText       String?
  createdAt          DateTime           @default(now())
  suggestionId       String
  suggestion         LocationSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@map("suggestion_photos")
}

model CompanySettings {
  id            String   @id @default(cuid())
  companyName   String   @default("Supreme Media Advertising")
  tagline       String?  @default("Creative • Innovative • Positive")
  gstNo         String?
  panNo         String?
  address       String?
  state         String?   @default("Tripura")
  bankName      String?
  accountName   String?
  accountNumber String?
  ifscCode      String?
  micrCode      String?
  branchCode    String?
  bankAddress   String?
  terms         String[]
  signatoryName String?  @default("Company Signator Name")
  signatureUrl  String?
  logoUrl       String?
  footerAddress String?
  website       String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("company_settings")
}

enum Illumination {
  LIT
  NON_LIT
  DIGITAL
}

enum HoldingStatus {
  AVAILABLE
  BOOKED
  UNDER_MAINTENANCE
  INACTIVE
}

enum AssetType {
  OWNED
  RENTED
}

enum OwnerType {
  GOVERNMENT
  MUNICIPAL
  VILLAGE_PANCHAYAT
  PRIVATE
}

enum RentCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum BookingStatus {
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AdStatus {
  PENDING
  INSTALLED
  ACTIVE
  REMOVED
  COMPLETED
}

enum UserRole {
  ADMIN
  STAFF
}

enum TaskType {
  INSTALLATION
  MOUNTING
  MAINTENANCE
  INSPECTION
  RELOCATION
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  UNDER_REVIEW
}

enum HoldingCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

enum MaintenanceType {
  PAINTING
  STRUCTURAL_REPAIR
  ELECTRICAL
  CLEANING
  REPLACEMENT
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum PaymentMode {
  CASH
  CHEQUE
  NEFT
  RTGS
  UPI
  CARD
  OTHER
}

enum LedgerType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
}

enum JournalSource {
  INVOICE
  RECEIPT
  PAYMENT
  MANUAL
}

enum JournalStatus {
  DRAFT
  POSTED
  VOID
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}
